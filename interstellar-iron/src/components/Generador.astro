<main>
  <h1>Generador de Colores</h1>
  <button id="btnColor">Generar Color</button>
  <p id="colorCode">#FFFFFF</p>
</main>

<script>
  function generarColor() {
  const letras = "0123456789ABCDEF";
  let color = "#";

  for (let i = 0; i < 6; i++) {
    color += letras[Math.floor(Math.random() * 16)];
  }

  return color;
}
  const boton = document.getElementById("btnColor");
const texto = document.getElementById("colorCode");

boton.addEventListener("click", () => {
  const nuevoColor = generarColor();

  document.body.style.backgroundColor = nuevoColor;
  texto.textContent = nuevoColor;
});
</script>



<style>
button {
  padding: 6px 50px;
  font-size: 14px;
  cursor: pointer;
  transition: transform 0.2s;
}
button:hover {
  transform: scale(1.2);
}
</style>